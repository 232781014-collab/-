PORT=3001

# bobdong.cn 中转（文案/诊断/图片）
BASE_URL=https://bobdong.cn/v1
TEXT_API_KEY=sk-你的文案Key
TEXT_MODEL=gpt-5.4
IMAGE_API_KEY=sk-你的图片Key
IMAGE_MODEL=gpt-image-2
VISION_API_KEY=sk-你的视觉Key
VISION_MODEL=gpt-5.4

# RedFoxHub（视频生成/链接解析/爆款雷达/图生图）
REDFOX_BASE=https://redfox.hk
REDFOX_API_KEY=ak_你的RedFoxKey
REDFOX_VIDEO_MODEL=doubao-seedance-2-0-260128
REDFOX_IMAGE_MODEL=doubao-seedream-5-0-260128

# 本地作品库（生成的图片/视频自动备份到这里）
GALLERY_DIR=./gallery

# TikHub.io（国内外平台数据，抖音热榜等）
TIKHUB_BASE=https://api.tikhub.io
TIKHUB_API_KEY=你的TikHubKey
